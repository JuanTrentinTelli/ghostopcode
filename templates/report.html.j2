  <h3>Ficheiros ({{ files | length }}) — metadata completa</h3>
  <table class="data">
    <thead><tr><th>Ficheiro</th><th>Tipo</th><th>Tamanho</th><th>Descarregado</th><th>Risco</th><th>URL</th><th>Metadata (JSON)</th></tr></thead>
    <tbody>
    {% for f in files %}
      <tr>
        <td>{{ f.filename | default('—') | e }}</td>
        <td>{{ f.type | default('—') | e }}</td>
        <td>{{ f.size | default('—') | e }}</td>
        <td>{{ f.downloaded | default(false) }}</td>
        <td>{% set rk = f.risk | default('INFO') %}<span class="badge {{ rk | lower | e }}">{{ rk | e }}</span></td>
        <td class="mono cell-long">{% if f.url %}<a href="{{ f.url | e }}" target="_blank" rel="noopener">{{ f.url | e }}</a>{% else %}—{% endif %}</td>
        <td class="cell-long">{{ (f.metadata | default({})) | json_pretty }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}
  {% if results.harvester.errors | default([]) %}
  <h3>Erros</h3>
  <ul class="compact">{% for e in results.harvester.errors %}<li>{{ e | e }}</li>{% endfor %}</ul>
  {% endif %}
  <details class="json-raw"><summary>JSON completo — Harvester</summary>{{ results.harvester | json_pretty }}</details>
</section>
{% endif %}

