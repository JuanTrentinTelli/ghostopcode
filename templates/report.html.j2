        {% endfor %}
      </div>
      <details class="json-raw"><summary>Cabeçalhos HTTP</summary>{{ http.headers | default({}) | json_pretty }}</details>
      <details class="json-raw"><summary>Cookies</summary>{{ http.cookies | default({}) | json_pretty }}</details>
      <details class="json-raw"><summary>tech_stack (estruturado)</summary>{{ results.whois_scan.tech_stack | default({}) | json_pretty }}</details>
    </div>
  </div>
  {% set flags = results.whois_scan.security_flags | default([]) %}
  {% if flags %}
  <h3>Security flags</h3>
  <table class="data"><thead><tr><th>Severidade</th><th>Problema</th><th>Detalhe</th></tr></thead><tbody>
    {% for flag in flags %}
