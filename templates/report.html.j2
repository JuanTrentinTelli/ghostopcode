      <tr>
        <td class="mono">{{ h | string | e }}</td>
        <td><span class="badge low">PRESENT</span></td>
        <td>—</td>
        <td>—</td>
      </tr>
    {% endfor %}
    {% for h in sec.exposed | default([]) %}
      <tr>
        <td class="mono">{{ h.header | default(h.name | default('—')) | e }}</td>
        <td><span class="badge high">EXPOSED</span></td>
        <td class="mono cell-long">{{ h.value | default('—') | e }}</td>
        <td>{% set rk = h.risk | default('HIGH') %}<span class="badge {{ rk | lower | e }}">{{ rk | e }}</span></td>
      </tr>
