<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>GhostOpcode — {{ session.target | e }}</title>
  <style>
    :root {
      --bg-primary:   #0d1117;
      --bg-secondary: #161b22;
      --bg-tertiary:  #21262d;
      --accent:       #00FF41;
      --critical:     #ff4444;
      --high:         #ffa500;
      --medium:       #ffcc00;
      --low:          #58a6ff;
      --text:         #e6edf3;
      --muted:        #8b949e;
      --border:       #30363d;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: ui-sans-serif, system-ui, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background: var(--bg-primary);
      color: var(--text);
      line-height: 1.55;
      font-size: 15px;
    }
    code, .mono { font-family: ui-monospace, "Cascadia Code", "JetBrains Mono", monospace; font-size: 0.88em; }
    a { color: var(--low); text-decoration: none; }
    a:hover { text-decoration: underline; }

    header {
      background: linear-gradient(160deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
      border-bottom: 1px solid var(--border);
      padding: 2rem 1.75rem 1.75rem;
    }
    .ascii-art {
      color: var(--accent);
      font-size: 0.55rem;
      line-height: 1.15;
      white-space: pre;
      margin: 0 0 1rem;
      opacity: 0.92;
      overflow-x: auto;
    }
    h1 {
      margin: 0;
      font-size: 1.65rem;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: -0.02em;
    }
    .meta {
      margin-top: 0.85rem;
      color: var(--muted);
      font-size: 0.92rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
    }
    .meta .target { color: var(--text); font-weight: 600; }
    .badge-row { margin-top: 1rem; display: flex; flex-wrap: wrap; gap: 0.35rem; }
    .badge-module {
      display: inline-block;
      padding: 0.25rem 0.65rem;
      border-radius: 999px;
      background: var(--bg-tertiary);
      border: 1px solid var(--border);
      font-size: 0.72rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    main { max-width: 1180px; margin: 0 auto; padding: 1.75rem 1.25rem 3rem; }

    .summary {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
      gap: 0.85rem;
      margin-bottom: 1.25rem;
    }
    .stat-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem 0.75rem;
      text-align: center;
    }
    .stat-card .number {
      font-size: 1.85rem;
      font-weight: 800;
      font-family: ui-monospace, monospace;
      line-height: 1.1;
    }
    .stat-card .label {
      font-size: 0.68rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-top: 0.35rem;
    }
    .stat-card.critical .number { color: var(--critical); }
    .stat-card.high .number { color: var(--high); }
    .stat-card.medium .number { color: var(--medium); }
    .stat-card.low .number { color: var(--low); }
    .stat-card.signals .number { color: var(--accent); }

    .risk-bar-wrap {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem 1.25rem;
      margin-bottom: 1.5rem;
    }
    .risk-bar-wrap h3 {
      margin: 0 0 0.65rem;
      font-size: 0.8rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .bar {
      display: flex;
      height: 12px;
      border-radius: 6px;
      overflow: hidden;
      background: var(--bg-tertiary);
    }
    .bar > div { height: 100%; min-width: 0; transition: width 0.3s ease; }
    .bar .critical { background: var(--critical); }
    .bar .high { background: var(--high); }
    .bar .medium { background: var(--medium); }
    .bar .low { background: var(--low); }
    .bar .info { background: var(--muted); }
    .risk-legend {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-top: 0.65rem;
      font-size: 0.78rem;
      color: var(--muted);
    }

    section.module {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.35rem 1.35rem 1.5rem;
      margin-bottom: 1.35rem;
    }
    section.module h2 {
      margin: 0 0 0.85rem;
      font-size: 1.12rem;
      color: var(--accent);
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.45rem;
    }
    section.module h3 {
      margin: 1.1rem 0 0.5rem;
      font-size: 0.95rem;
      color: var(--text);
    }
    .status-pill {
      display: inline-block;
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      font-size: 0.72rem;
      font-weight: 600;
      background: var(--bg-tertiary);
      color: var(--muted);
      margin-bottom: 0.75rem;
    }
    .muted { color: var(--muted); font-size: 0.88rem; }

    table.data {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.86rem;
    }
    table.data th, table.data td {
      text-align: left;
      padding: 0.5rem 0.6rem;
      border-bottom: 1px solid var(--border);
    }
    table.data th {
      color: var(--muted);
      font-weight: 600;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    table.data tbody tr:hover td { background: rgba(0, 255, 65, 0.035); }

    .badge {
      display: inline-block;
      padding: 0.12rem 0.42rem;
      border-radius: 4px;
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
    }
    .badge.critical { background: rgba(255,68,68,0.22); color: var(--critical); }
    .badge.high { background: rgba(255,165,0,0.18); color: var(--high); }
    .badge.medium { background: rgba(255,204,0,0.15); color: var(--medium); }
    .badge.low { background: rgba(88,166,255,0.18); color: var(--low); }
    .badge.info { background: var(--bg-tertiary); color: var(--muted); }

    .alert {
      border-radius: 8px;
      padding: 0.75rem 1rem;
      margin: 0.65rem 0;
      border-left: 4px solid var(--muted);
      background: var(--bg-tertiary);
      font-size: 0.9rem;
    }
    .alert.critical { border-left-color: var(--critical); background: rgba(255,68,68,0.08); }
    .alert.high { border-left-color: var(--high); background: rgba(255,165,0,0.08); }

    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }
    @media (max-width: 820px) { .two-col { grid-template-columns: 1fr; } }

    dl.kv {
      display: grid;
      grid-template-columns: 140px 1fr;
      gap: 0.35rem 0.75rem;
      font-size: 0.88rem;
    }
    dl.kv dt { color: var(--muted); margin: 0; }
    dl.kv dd { margin: 0; }

    .intel .badge { margin: 0.15rem 0.25rem 0.15rem 0; }

    .json-dump {
      font-size: 0.72rem;
      line-height: 1.4;
      white-space: pre-wrap;
      word-break: break-word;
      max-height: 75vh;
      overflow: auto;
      background: var(--bg-tertiary);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.75rem;
      margin: 0.35rem 0 0;
    }
    details.json-raw { margin-top: 1rem; }
    details.json-raw > summary {
      cursor: pointer;
      color: var(--muted);
      font-size: 0.82rem;
      user-select: none;
    }
    .cell-long {
      max-width: min(560px, 100%);
      white-space: pre-wrap;
      word-break: break-word;
      font-size: 0.78rem;
      vertical-align: top;
    }
    ul.compact { margin: 0.35rem 0; padding-left: 1.2rem; font-size: 0.86rem; color: var(--muted); }

    footer {
      text-align: center;
      padding: 2rem 1rem;
      color: var(--muted);
      font-size: 0.82rem;
      border-top: 1px solid var(--border);
      margin-top: 1rem;
    }
  </style>
</head>
<body>

<header>
<pre class="ascii-art"> ██████╗ ██╗  ██╗ ██████╗ ███████╗████████╗ ██████╗ ██████╗  ██████╗ ██████╗ ███████╗
██╔════╝ ██║  ██║██╔═══██╗██╔════╝╚══██╔══╝██╔═══██╗██╔══██╗██╔═══██╗██╔══██╗██╔════╝
██║  ███╗███████║██║   ██║███████╗   ██║   ██║   ██║██████╔╝██║   ██║██║  ██║█████╗
██║   ██║██╔══██║██║   ██║╚════██║   ██║   ██║   ██║██╔═══╝ ██║   ██║██║  ██║██╔══╝
╚██████╔╝██║  ██║╚██████╔╝███████║   ██║   ╚██████╔╝██║     ╚██████╔╝██████╔╝███████╗
 ╚═════╝ ╚═╝  ╚═╝ ╚═════╝ ╚══════╝   ╚═╝    ╚═════╝ ╚═╝      ╚═════╝ ╚═════╝ ╚══════╝</pre>
  <h1>Relatório de reconhecimento</h1>
  <div class="meta">
    <span><strong>Alvo:</strong> <span class="mono target">{{ session.target | e }}</span></span>
    <span><strong>Tipo:</strong> {{ session.target_type | e }}</span>
    <span><strong>Início:</strong> {{ session.timestamp | e }}</span>
    <span><strong>Duração:</strong> {{ session.duration | e }}</span>
  </div>
  <div class="badge-row">
    {% for mod in session.modules_run %}
    <span class="badge-module">{{ module_labels.get(mod, mod) | e }}</span>
    {% endfor %}
  </div>
</header>

<main>

<section class="risk-bar-wrap" style="margin-top:0">
  <h3>Resumo executivo</h3>
  <div class="summary">
    <div class="stat-card signals"><div class="number">{{ summary.total_findings }}</div><div class="label">Sinais</div></div>
    <div class="stat-card critical"><div class="number">{{ summary.critical }}</div><div class="label">Critical</div></div>
    <div class="stat-card high"><div class="number">{{ summary.high }}</div><div class="label">High</div></div>
    <div class="stat-card medium"><div class="number">{{ summary.medium }}</div><div class="label">Medium</div></div>
    <div class="stat-card low"><div class="number">{{ summary.low }}</div><div class="label">Low</div></div>
    <div class="stat-card"><div class="number">{{ session.modules_run | length }}</div><div class="label">Módulos</div></div>
  </div>
  <h3>Distribuição por severidade (risk_summary)</h3>
  <div class="bar">
    <div class="critical" style="width: {{ summary.critical_pct }}%" title="Critical"></div>
    <div class="high" style="width: {{ summary.high_pct }}%" title="High"></div>
    <div class="medium" style="width: {{ summary.medium_pct }}%" title="Medium"></div>
    <div class="low" style="width: {{ summary.low_pct }}%" title="Low"></div>
    <div class="info" style="width: {{ summary.info_pct }}%" title="Info"></div>
  </div>
  <div class="risk-legend">
    <span>Critical {{ summary.critical }} ({{ summary.critical_pct }}%)</span>
    <span>High {{ summary.high }} ({{ summary.high_pct }}%)</span>
    <span>Medium {{ summary.medium }} ({{ summary.medium_pct }}%)</span>
    <span>Low {{ summary.low }} ({{ summary.low_pct }}%)</span>
    {% if summary.info %}<span>Info {{ summary.info }} ({{ summary.info_pct }}%)</span>{% endif %}
  </div>
</section>

{# --- DNS --- #}
{% if results.get('dns_recon') and results.dns_recon.status != 'skipped' %}
<section class="module" id="dns">
  <h2>DNS Recon</h2>
  <span class="status-pill">Status: {{ results.dns_recon.status | e }}</span>
  {% if results.dns_recon.get('error') %}<p class="muted">{{ results.dns_recon.error | e }}</p>{% endif %}
  {% set dns_errors = results.dns_recon.errors | default([]) %}
  {% if dns_errors %}
  <h3>Erros / avisos</h3>
  <ul class="compact">{% for e in dns_errors %}<li>{{ e | e }}</li>{% endfor %}</ul>
  {% endif %}
  <p class="muted">Total de registos: <strong>{{ results.dns_recon.total_records | default(0) }}</strong></p>
  {% set ax = results.dns_recon.axfr | default({}) %}
  <h3>AXFR (zone transfer)</h3>
  <dl class="kv">
    <dt>Tentado</dt><dd>{{ ax.attempted | default(false) }}</dd>
    <dt>Vulnerável</dt><dd>{{ ax.vulnerable | default(false) }}</dd>
    <dt>Nameservers tentados</dt><dd class="cell-long">{{ (ax.nameservers_tried | default([])) | join(', ') | e }}</dd>
  </dl>
  {% if ax.get('vulnerable') %}
  <div class="alert critical"><strong>ZONE TRANSFER (AXFR) VULNERÁVEL</strong></div>
  {% endif %}
  {% set dump = ax.dump | default([]) %}
  {% if dump %}
  <h4>Dump AXFR ({{ dump | length }} linhas)</h4>
  <pre class="mono json-dump" style="max-height:45vh">{{ dump | join('\n') | e }}</pre>
  {% endif %}
  {% set rec = results.dns_recon.records | default({}) %}
  <h3>Registos DNS</h3>
  <table class="data">
    <thead><tr><th>Tipo</th><th>Valor</th><th>Detalhe</th></tr></thead>
    <tbody>
    {% for ip in rec.A | default([]) %}
      <tr><td>A</td><td class="mono">{{ ip | e }}</td><td>IPv4</td></tr>
    {% endfor %}
    {% for ip in rec.AAAA | default([]) %}
      <tr><td>AAAA</td><td class="mono">{{ ip | e }}</td><td>IPv6</td></tr>
    {% endfor %}
    {% for mx in rec.MX | default([]) %}
      <tr><td>MX</td><td class="mono">{{ mx.host | default(mx) | e }}</td><td>prio {{ mx.priority | default('—') }}</td></tr>
    {% endfor %}
    {% for ns in rec.NS | default([]) %}
      <tr><td>NS</td><td class="mono">{{ ns | e }}</td><td>—</td></tr>
    {% endfor %}
    {% for t in rec.TXT | default([]) %}
      <tr><td>TXT</td><td class="mono cell-long">{{ t | e }}</td><td>—</td></tr>
    {% endfor %}
    {% for c in rec.CNAME | default([]) %}
      <tr><td>CNAME</td><td class="mono">{{ c | e }}</td><td>—</td></tr>
    {% endfor %}
    {% set soa = rec.SOA | default({}) %}
    {% if soa %}
      <tr><td>SOA</td><td class="mono cell-long" colspan="2">mname={{ soa.mname | default('') | e }} · rname={{ soa.rname | default('') | e }} · serial={{ soa.serial | default('') }}</td></tr>
    {% endif %}
    {% for s in rec.SRV | default([]) %}
      <tr><td>SRV</td><td class="mono cell-long">{{ s | e }}</td><td>—</td></tr>
    {% endfor %}
    {% for c in rec.CAA | default([]) %}
      <tr><td>CAA</td><td class="mono cell-long">{{ c | e }}</td><td>—</td></tr>
    {% endfor %}
    {% for p in rec.PTR | default([]) %}
      <tr><td>PTR</td><td class="mono">{{ p | e }}</td><td>—</td></tr>
    {% endfor %}
    </tbody>
  </table>
  {% set tech = results.dns_recon.technologies | default([]) %}
  {% if tech %}
  <div class="intel"><strong>Tecnologias inferidas (DNS):</strong>
    {% for t in tech %}<span class="badge info">{{ t | string | e }}</span>{% endfor %}
  </div>
  {% endif %}
  <details class="json-raw"><summary>JSON completo — DNS Recon</summary>{{ results.dns_recon | json_pretty }}</details>
</section>
{% endif %}

{# --- Subdomains --- #}
{% if results.get('subdomain_enum') and results.subdomain_enum.status != 'skipped' %}
<section class="module" id="subs">
  <h2>Enumeração de subdomínios</h2>
  <span class="status-pill">Status: {{ results.subdomain_enum.status | e }}</span>
  {% set sub_stats = results.subdomain_enum.stats | default({}) %}
  {% set wc = results.subdomain_enum.wildcard | default({}) %}
  <p class="muted">Resolvidos: {{ sub_stats.resolved | default((results.subdomain_enum.found | default([])) | length) }} · filtrados (wildcard): {{ sub_stats.filtered | default('—') }} · wordlist: {{ sub_stats.wordlist_size | default('—') }} · duração: {{ sub_stats.duration_s | default('—') }}s · req/s: {{ sub_stats.req_per_sec | default('—') }}</p>
  <p class="muted">Wildcard DNS: {% if wc.detected %}detetado → <span class="mono">{{ wc.ip | default('?') | e }}</span>{% else %}não detetado{% endif %}</p>
  {% set cat = results.subdomain_enum.categories | default({}) %}
  <h3>Categorias por risco (FQDN)</h3>
  {% for risk in ['CRITICAL','HIGH','MEDIUM','LOW'] %}
    {% set lst = cat.get(risk, []) %}
    {% if lst %}
    <h4>{{ risk }} ({{ lst | length }})</h4>
    <p class="intel">{% for fq in lst %}<span class="badge info mono">{{ fq | e }}</span> {% endfor %}</p>
    {% endif %}
  {% endfor %}
  <h3>Subdomínios (detalhe)</h3>
  <table class="data">
    <thead><tr><th>FQDN</th><th>Sub</th><th>IPs</th><th>CNAME</th><th>Categoria</th><th>Risco</th><th>Takeover</th></tr></thead>
    <tbody>
    {% for sub in results.subdomain_enum.found | default([]) %}
      <tr>
        <td class="mono">{{ sub.fqdn | default(sub.host | default(sub)) | string | e }}</td>
        <td class="mono">{{ sub.subdomain | default('—') | e }}</td>
        <td class="cell-long">{{ (sub.ips | default([])) | join(', ') | e }}</td>
        <td class="mono cell-long">{{ sub.cname | default('—') | e }}</td>
        <td>{{ sub.category | default('—') | e }}</td>
        <td>{% set rk = sub.risk | default('INFO') %}<span class="badge {{ rk | lower | e }}">{{ rk | e }}</span></td>
        <td>{% if sub.takeover %}<span class="badge high">sim</span>{% else %}—{% endif %}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% set toc = results.subdomain_enum.takeover_candidates | default([]) %}
  {% if toc %}
  <h3>Candidatos a takeover / dangling</h3>
  <table class="data">
    <thead><tr><th>FQDN</th><th>CNAME</th><th>Nota</th></tr></thead>
    <tbody>
    {% for t in toc %}
      <tr>
        <td class="mono">{{ t.fqdn | default(t.host | default('—')) | e }}</td>
        <td class="mono cell-long">{{ t.cname | default('—') | e }}</td>
        <td class="cell-long">{{ t.note | default('—') | e }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}
  {% if results.subdomain_enum.errors | default([]) %}
  <h3>Erros</h3>
  <ul class="compact">{% for e in results.subdomain_enum.errors %}<li>{{ e | e }}</li>{% endfor %}</ul>
  {% endif %}
  <details class="json-raw"><summary>JSON completo — Subdomain enum</summary>{{ results.subdomain_enum | json_pretty }}</details>
</section>
{% endif %}

{# --- WHOIS --- #}
{% if results.get('whois_scan') and results.whois_scan.status not in ['skipped'] %}
<section class="module" id="whois">
  <h2>WHOIS + Fingerprint HTTP</h2>
  <span class="status-pill">Status: {{ results.whois_scan.status | e }}</span>
  {% if results.whois_scan.get('error') %}<p class="muted">{{ results.whois_scan.error | e }}</p>{% endif %}
  {% set w = results.whois_scan.whois | default({}) %}
  <div class="two-col">
    <div>
      <h3>WHOIS (domínio ou IP)</h3>
      <dl class="kv">
        <dt>Alvo</dt><dd class="mono">{{ w.domain_name | default(w.ip | default('—')) | string | e }}</dd>
        <dt>Registrar</dt><dd>{{ w.registrar | default('—') | string | e }}</dd>
        <dt>Organização</dt><dd>{{ w.org | default('—') | string | e }}</dd>
        <dt>Responsável</dt><dd>{{ w.responsible | default('—') | string | e }}</dd>
        <dt>Emails</dt><dd class="cell-long">{{ (w.emails | default([])) | join(', ') | e }}</dd>
        <dt>ASN / ISP</dt><dd>{{ w.asn | default('—') | e }} {% if w.asn_org %}· {{ w.asn_org | e }}{% endif %}{% if w.isp %} / {{ w.isp | e }}{% endif %}</dd>
        <dt>Abuse</dt><dd>{{ w.abuse_email | default('—') | e }}</dd>
        <dt>País / Cidade</dt><dd>{{ w.country | default('—') | e }}{% if w.city %} · {{ w.city | e }}{% endif %}</dd>
        <dt>Range IP</dt><dd class="mono">{{ w.ip_range | default('—') | e }}</dd>
        <dt>Registrado</dt><dd>{{ w.registered_on | default('—') | string | e }}</dd>
        <dt>Atualizado</dt><dd>{{ w.updated_on | default('—') | string | e }}</dd>
        <dt>Expira</dt><dd>{{ w.expires_on | default('—') | string | e }} {% if w.days_to_expire is not none %}({{ w.days_to_expire }} dias){% endif %}</dd>
        <dt>Estado(s)</dt><dd class="cell-long">{{ (w.status | default([])) | join('; ') | e }}</dd>
        <dt>NS</dt><dd class="cell-long">{{ (w.nameservers | default([])) | join(', ') | e }}</dd>
        <dt>Privacy guard</dt><dd>{{ w.privacy_guard | default(false) }}</dd>
        <dt>Erro WHOIS</dt><dd>{{ w.error | default(false) }} {% if w.error_message %}{{ w.error_message | e }}{% endif %}</dd>
      </dl>
      {% if w.raw %}
      <details class="json-raw"><summary>WHOIS raw (pré-visualização)</summary><pre class="mono json-dump">{{ (w.raw | string)[:25000] | e }}{% if (w.raw | string | length) > 25000 %}…{% endif %}</pre></details>
      {% endif %}
    </div>
    <div>
      <h3>HTTP / SSL / tecnologias</h3>
      {% set http = results.whois_scan.http | default({}) %}
      <dl class="kv">
        <dt>Alcançável</dt><dd>{{ http.reachable | default(false) }}</dd>
        <dt>Protocolo</dt><dd>{{ http.protocol | default('—') | e }}</dd>
        <dt>HTTP status</dt><dd>{{ http.status_code | default('—') }} {{ http.status_reason | default('') | e }}</dd>
        <dt>URL final</dt><dd class="mono cell-long">{{ http.final_url | default('—') | e }}</dd>
      </dl>
      {% if http.redirect_chain %}
      <h4>Cadeia de redirects</h4>
      <ul class="compact">{% for u in http.redirect_chain %}<li class="mono">{{ u | e }}</li>{% endfor %}</ul>
      {% endif %}
      {% set ssl = http.ssl | default({}) %}
      <dl class="kv" style="margin-top:0.75rem">
        <dt>Emissor</dt><dd class="cell-long">{{ ssl.issuer | default('—') | string | e }}</dd>
        <dt>Expira SSL</dt><dd>{{ ssl.expires_on | default(ssl.not_after | default('—')) | string | e }}</dd>
        <dt>SANs</dt><dd class="cell-long">{{ (ssl.sans | default([])) | join(', ') | e }}</dd>
      </dl>
