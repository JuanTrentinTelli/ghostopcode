    <dt>Leaks</dt><dd>{{ results.harvester.stats.leaks_found | default('—') }}</dd>
    <dt>Duração</dt><dd>{{ results.harvester.stats.duration_s | default('—') }}s</dd>
  </dl>
  {% set intel = results.harvester.intelligence | default({}) %}
  {% if intel %}
  <h3>Correlação / intelligence</h3>
  <dl class="kv">
    <dt>Usernames (metadata + emails + LinkedIn)</dt><dd class="cell-long">{{ (intel.usernames | default([])) | join(', ') | e }}</dd>
    <dt>Software stack</dt><dd class="cell-long">{{ (intel.software_stack | default([])) | join(', ') | e }}</dd>
    <dt>Internal paths</dt><dd class="cell-long">{{ (intel.internal_paths | default([])) | join(', ') | e }}</dd>
    <dt>Emails em documentos</dt><dd class="cell-long">{{ (intel.emails_in_docs | default([])) | join(', ') | e }}</dd>
    <dt>Intervalo de datas (docs)</dt><dd>{% set cr = intel.creation_range | default([]) %}{% if cr | length >= 2 %}{{ cr[0] | e }} → {{ cr[1] | e }}{% else %}—{% endif %}</dd>
    <dt>AD domain guess</dt><dd class="mono">{{ intel.ad_domain_guess | default('—') | e }}</dd>
    <dt>Totais</dt><dd>emails: {{ intel.emails_total | default('—') }} · ficheiros: {{ intel.files_total | default('—') }} · leaks: {{ intel.leaks_total | default('—') }}</dd>
  </dl>
  {% set lip = intel.linkedin_profiles | default([]) %}
  {% if lip %}
  <h4>Perfis LinkedIn (handles / URLs)</h4>
  <p class="intel">{% for h in lip %}<span class="badge info mono">{{ h | e }}</span> {% endfor %}</p>
  {% endif %}
  {% endif %}
  {% set emails = results.harvester.emails | default([]) %}
  {% if emails %}
  <h3>Emails & identidades (todos)</h3>
  <table class="data">
    <thead><tr><th>Email / ID</th><th>LinkedIn</th><th>Nome</th><th>Função</th><th>Tipo</th><th>Origem</th></tr></thead>
    <tbody>
    {% for e in emails %}
      <tr>
        <td>{{ e.email | default(e.linkedin | default('—')) | e }}</td>
        <td class="mono cell-long">{% if e.linkedin %}<a href="{{ e.linkedin | e }}" rel="noopener" target="_blank">{{ e.linkedin | e }}</a>{% else %}—{% endif %}</td>
        <td>{{ e.name | default('—') | e }}</td>
        <td>{{ e.role | default('—') | e }}</td>
        <td>{{ e.kind | default('—') | e }}</td>
        <td class="muted cell-long">{{ e.source | default('—') | e }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}
  {% set leaks = results.harvester.config_leaks | default([]) %}
  {% for leak in leaks %}
  <div class="alert {% if leak.confirmed %}critical{% else %}high{% endif %}">
    <strong>{{ leak.path | e }}</strong> — HTTP {{ leak.status | default('—') }}{% if leak.confirmed is defined %} · confirmado: {{ leak.confirmed }}{% endif %}
    {% if leak.secrets %}
    <ul>
      {% for s in leak.secrets %}
      <li>{{ s.type | default('secret') | e }}{% if s.line %} (linha {{ s.line }}){% endif %}: <code class="cell-long">{{ s.value | default('') | e }}</code></li>
      {% endfor %}
    </ul>
    {% endif %}
    <details class="json-raw"><summary>Leak (JSON completo)</summary>{{ leak | json_pretty }}</details>
  </div>
