  <h3>Endpoints ({{ eps | length }})</h3>
  <table class="data">
    <thead><tr><th>Endpoint</th><th>Método</th><th>Fonte</th><th>Categoria</th><th>Risco</th><th>Notas</th></tr></thead>
    <tbody>
    {% for ep in eps %}
      <tr>
        <td class="mono cell-long">{{ ep.url | e }}</td>
        <td>{{ ep.method | default('—') | e }}</td>
        <td>{{ ep.source | default('—') | e }}</td>
        <td>{{ ep.category | default('—') | e }}</td>
        <td>{% set rk = ep.risk | default('INFO') %}<span class="badge {{ rk | lower | e }}">{{ rk | e }}</span></td>
        <td class="cell-long">{{ ep.note | default(ep.details | default('—')) | string | e }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}
  {% for s in results.js_recon.secrets | default([]) %}
  <div class="alert critical">{{ s.type | e }} em <span class="mono">{{ s.source | e }}</span>: <code class="cell-long">{{ s.value | e }}</code></div>
  {% endfor %}
  {% set sms = results.js_recon.source_maps | default([]) %}
  {% if sms %}
  <h3>Source maps</h3>
  {% for sm in sms %}
  <details class="json-raw"><summary><span class="mono">{{ sm.url | default('inline') | e }}</span> — {{ sm.sources_count | default(0) }} ficheiros{% if sm.has_content %} · <strong>código embutido</strong>{% endif %}</summary>{{ sm | json_pretty }}</details>
  {% endfor %}
  {% endif %}
  {% if results.js_recon.errors | default([]) %}
  <h3>Erros</h3>
  <ul class="compact">{% for e in results.js_recon.errors %}<li>{{ e | e }}</li>{% endfor %}</ul>
  {% endif %}
  <details class="json-raw"><summary>JSON completo — JS recon</summary>{{ results.js_recon | json_pretty }}</details>
</section>
{% endif %}

{# --- WAF detection --- #}
{% if results.get('waf_detect') and results.waf_detect.status not in ['skipped'] %}
<section class="module" id="waf">
  <h2>WAF detection</h2>
  <span class="status-pill">Status: {{ results.waf_detect.status | e }}</span>
  <p class="muted">Base: <span class="mono">{{ results.waf_detect.base_url | default('—') | e }}</span></p>
  <dl class="kv">
    <dt>WAF detectado</dt><dd>{{ results.waf_detect.waf_detected | default(false) }}</dd>
    <dt>Sem WAF (heurística)</dt><dd>{{ results.waf_detect.no_waf_detected | default('—') }}</dd>
  </dl>
  {% if results.waf_detect.waf %}
  {% set w = results.waf_detect.waf %}
  <h3>Vendor / tipo</h3>
  <dl class="kv">
    <dt>Nome</dt><dd>{{ w.name | e }}</dd>
    <dt>Tipo</dt><dd>{{ w.type | e }}</dd>
    <dt>Confiança</dt><dd>{{ w.confidence | e }}</dd>
    <dt>Nota</dt><dd class="cell-long">{{ w.note | default('—') | e }}</dd>
    <dt>Evasão (hint)</dt><dd class="cell-long">{{ w.evasion | default('—') | e }}</dd>
  </dl>
  {% endif %}
  {% set dm = results.waf_detect.detection_methods | default({}) %}
  <h3>Métodos</h3>
  <ul class="compact">
    <li>Passive headers: {{ dm.passive_headers | default(false) }}</li>
    <li>Active probes: {{ dm.active_probes | default(false) }}</li>
    <li>Timing: {{ dm.timing | default(false) }}</li>
  </ul>
  {% set pr = results.waf_detect.probes | default([]) %}
  {% if pr %}
  <h3>Probes</h3>
  <table class="data">
    <thead><tr><th>Probe</th><th>Bloqueado</th><th>HTTP</th></tr></thead>
    <tbody>
    {% for p in pr %}
      <tr>
        <td>{{ p.probe | e }}</td>
        <td>{{ p.blocked | default(false) }}</td>
        <td>{{ p.status | default('—') }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}
  {% set tm = results.waf_detect.timing | default({}) %}
  {% if tm %}
  <h3>Timing</h3>
  <dl class="kv">
    <dt>Média normal (ms)</dt><dd>{{ tm.avg_normal_ms | default('—') }}</dd>
    <dt>Média probe (ms)</dt><dd>{{ tm.avg_probe_ms | default('—') }}</dd>
    <dt>Δ delay (ms)</dt><dd>{{ tm.delay_ms | default('—') }}</dd>
    <dt>Inspeção provável</dt><dd>{{ tm.inspection_likely | default(false) }}</dd>
  </dl>
  {% endif %}
  {% if results.waf_detect.errors | default([]) %}
  <h3>Erros</h3>
  <ul class="compact">{% for e in results.waf_detect.errors %}<li>{{ e | e }}</li>{% endfor %}</ul>
  {% endif %}
  <details class="json-raw"><summary>JSON completo — WAF detection</summary>{{ results.waf_detect | json_pretty }}</details>
</section>
{% endif %}

{# --- URL harvester --- #}
{% if results.get('url_harvester') and results.url_harvester.status not in ['skipped'] %}
<section class="module" id="url-harvest">
  <h2>URL harvester</h2>
  <span class="status-pill">Status: {{ results.url_harvester.status | e }}</span>
  <p class="muted">Alvo: <span class="mono">{{ results.url_harvester.target | e }}</span></p>
  {% set src = results.url_harvester.sources | default({}) %}
  <h3>Fontes</h3>
  <ul class="compact">
    {% for k, v in src | dictsort %}
    <li><strong>{{ k | e }}</strong>: {{ (v.count | default(0)) }} URLs
        {% if v.available is defined %}· disponível: {{ v.available }}{% endif %}</li>
    {% endfor %}
  </ul>
  {% set uh = results.url_harvester.stats | default({}) %}
  <dl class="kv">
    <dt>Total (merge)</dt><dd>{{ results.url_harvester.total_urls | default('—') }}</dd>
    <dt>Único (dedup params)</dt><dd>{{ results.url_harvester.unique_urls | default('—') }}</dd>
    <dt>Raw coletado (soma fontes)</dt><dd>{{ uh.total_collected | default('—') }}</dd>
    <dt>Duração</dt><dd>{{ uh.duration_s | default('—') }}s</dd>
  </dl>
  {% set fd = results.url_harvester.findings | default({}) %}
  {% if fd %}
  <h3>Padrões (amostra)</h3>
  {% for cat, lst in fd | dictsort %}
  <h4>{{ cat | e }} ({{ lst | length }})</h4>
  <ul class="compact mono">{% for u in lst[:25] %}<li>{{ u | e }}</li>{% endfor %}{% if lst | length > 25 %}<li>…</li>{% endif %}</ul>
  {% endfor %}
  {% endif %}
  {% if results.url_harvester.errors | default([]) %}
  <h3>Erros</h3>
  <ul class="compact">{% for e in results.url_harvester.errors %}<li>{{ e | e }}</li>{% endfor %}</ul>
  {% endif %}
  <details class="json-raw"><summary>JSON completo — URL harvester</summary>{{ results.url_harvester | json_pretty }}</details>
</section>
{% endif %}

{# --- Subfinder enum --- #}
{% if results.get('subfinder_enum') and results.subfinder_enum.status not in ['skipped'] %}
<section class="module" id="subfinder">
  <h2>Subfinder enum</h2>
  <span class="status-pill">Status: {{ results.subfinder_enum.status | e }}</span>
  <p class="muted">Alvo: <span class="mono">{{ results.subfinder_enum.target | e }}</span> · subfinder {{ results.subfinder_enum.subfinder_version | default('—') | e }}</p>
  {% set ast = results.subfinder_enum.stats | default({}) %}
  <dl class="kv">
    <dt>Total (hostnames)</dt><dd>{{ ast.total_found | default('—') }}</dd>
    <dt>Resolvidos</dt><dd>{{ ast.resolved | default('—') }}</dd>
    <dt>Não resolvidos</dt><dd>{{ ast.unresolved | default('—') }}</dd>
    <dt>Novos vs wordlist</dt><dd>{{ ast.new_vs_wordlist | default('—') }}</dd>
    <dt>Duração</dt><dd>{{ ast.duration_s | default('—') }}s</dd>
  </dl>
  {% set cmp = results.subfinder_enum.comparison | default({}) %}
  <h3>Comparação com subdomain enum</h3>
  <ul class="compact">
    <li>Ambos: {{ (cmp.both | default([])) | length }}</li>
    <li>Só wordlist: {{ (cmp.only_wordlist | default([])) | length }}</li>
    <li>Só subfinder: {{ (cmp.only_subfinder | default([])) | length }}</li>
  </ul>
  {% set af = results.subfinder_enum.found | default([]) %}
  {% if af %}
  <h3>Hosts</h3>
  <table class="data">
    <thead><tr><th>FQDN</th><th>IP</th><th>Categoria</th><th>Risco</th><th>Novo*</th></tr></thead>
    <tbody>
    {% for row in af[:200] %}
      <tr>
        <td class="mono">{{ row.fqdn | e }}</td>
        <td class="mono">{{ row.ip | default('—') | e }}</td>
        <td>{{ row.category_label | default(row.category) | e }}</td>
        <td><span class="badge {{ (row.risk | string | lower) | e }}">{{ row.risk | e }}</span></td>
        <td>{% if row.new %}★{% else %}—{% endif %}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% if af | length > 200 %}<p class="muted">Mostrando 200 de {{ af | length }}.</p>{% endif %}
  {% endif %}
  {% if results.subfinder_enum.errors | default([]) %}
  <h3>Erros</h3>
  <ul class="compact">{% for e in results.subfinder_enum.errors %}<li>{{ e | e }}</li>{% endfor %}</ul>
  {% endif %}
  <details class="json-raw"><summary>JSON completo — Subfinder</summary>{{ results.subfinder_enum | json_pretty }}</details>
</section>
{% endif %}

{# --- CVE lookup --- #}
{% if results.get('cve_lookup') %}
<section class="module" id="cve">
  <h2>CVE lookup (NVD)</h2>
  <span class="status-pill">{{ results.cve_lookup.status | e }}</span>
  {% set sm = results.cve_lookup.summary | default({}) %}
  <dl class="kv">
    <dt>Alvos verificados</dt><dd>{{ results.cve_lookup.targets_checked | default(0) }}</dd>
    <dt>CVEs (linhas)</dt><dd>{{ sm.total_cves_found | default(0) }}</dd>
    <dt>Critical / High / Med / Low</dt><dd>{{ sm.critical | default(0) }} / {{ sm.high | default(0) }} / {{ sm.medium | default(0) }} / {{ sm.low | default(0) }}</dd>
    <dt>CISA KEV</dt><dd>{{ sm.in_cisa_kev | default(0) }}</dd>
    <dt>Duração</dt><dd>{{ (results.cve_lookup.stats | default({})).duration_s | default('—') }}s</dd>
  </dl>
  {% set sk = results.cve_lookup.skipped_targets | default([]) %}
  {% if sk %}
  <h3>Alvos ignorados (termo genérico / IANA / nmap)</h3>
  <p class="muted cell-long">{{ sk | join(' · ') | e }}</p>
  {% endif %}
  {% for block in results.cve_lookup.findings | default([]) %}
  <h3 class="mono">{{ block.software | e }}{% if block.version %} {{ block.version | e }}{% endif %} <span class="muted">({{ block.source | e }})</span></h3>
  {% if block.cves %}
  <table class="data">
    <thead><tr><th>CVE</th><th>CVSS</th><th>Severidade</th><th>KEV</th><th>Publicado</th><th>Descrição</th></tr></thead>
    <tbody>
    {% for c in block.cves %}
      <tr>
        <td class="mono"><a href="{{ c.nvd_url | e }}" rel="noopener" target="_blank">{{ c.cve_id | e }}</a></td>
        <td>{{ c.cvss_score | default('—') }}</td>
        <td>{% set rk = c.cvss_severity | default('—') %}<span class="badge {{ (rk | string | lower) | e }}">{{ rk | e }}</span></td>
        <td>{% if c.cisa_kev %}<span class="badge critical">KEV</span>{% else %}—{% endif %}</td>
        <td>{{ c.published | default('—') | e }}</td>
        <td class="cell-long">{{ c.description | default('—') | e }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="muted">Sem resultados NVD para esta consulta.</p>
  {% endif %}
  {% endfor %}
  {% if results.cve_lookup.errors | default([]) %}
  <ul class="compact">{% for e in results.cve_lookup.errors %}<li>{{ e | e }}</li>{% endfor %}</ul>
  {% endif %}
  <details class="json-raw"><summary>JSON completo — CVE lookup</summary>{{ results.cve_lookup | json_pretty }}</details>
</section>
{% endif %}

{# --- Hash --- #}
{% if results.get('hash_module') %}
<section class="module" id="hash">
  <h2>Hash module</h2>
  <span class="status-pill">{{ results.hash_module.status | e }}</span>
  <p class="mono muted">{{ results.hash_module.hash | default('') | e }}</p>
  {% if results.hash_module.candidates %}
  <table class="data">
    <thead><tr><th>Algoritmo</th><th>Conf.</th><th>Hashcat</th><th>Risco</th></tr></thead>
    <tbody>
    {% for c in results.hash_module.candidates %}
      <tr>
        <td>{{ c.algorithm | e }}</td>
        <td>{{ c.confidence | default('—') | e }}</td>
        <td>{{ c.hashcat_mode | default('—') }}</td>
        <td>{% set rk = c.risk | default('INFO') %}<span class="badge {{ rk | lower | e }}">{{ rk | e }}</span></td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}
  {% set cr = results.hash_module.crack_result | default({}) %}
  {% if cr.cracked and cr.plaintext %}
  <div class="alert high"><strong>Crack:</strong> <code>{{ cr.plaintext | e }}</code> ({{ cr.method | default('—') | e }})</div>
  {% endif %}
  <details class="json-raw"><summary>JSON completo — Hash module</summary>{{ results.hash_module | json_pretty }}</details>
</section>
{% endif %}

{# --- ARP --- #}
{% if results.get('arp_scan') and results.arp_scan.status == 'success' %}
<section class="module" id="arp">
  <h2>ARP Scan</h2>
  <p class="muted">{{ results.arp_scan.stats.hosts_found | default(0) }} hosts em {{ results.arp_scan.network | default(results.arp_scan.target | default('—')) | e }}</p>
  <table class="data">
    <thead><tr><th>IP</th><th>MAC</th><th>Vendor</th><th>Hostname</th><th>Risco</th></tr></thead>
    <tbody>
    {% for host in results.arp_scan.hosts | default([]) %}
      <tr>
        <td>{{ host.ip | e }}</td>
        <td class="mono">{{ host.mac | e }}</td>
        <td>{{ host.vendor | e }}</td>
        <td>{{ host.hostname | default('—') | e }}</td>
        <td>{% set rk = host.risk | default('LOW') %}<span class="badge {{ rk | lower | e }}">{{ rk | e }}</span></td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  <details class="json-raw"><summary>JSON completo — ARP scan</summary>{{ results.arp_scan | json_pretty }}</details>
</section>
{% endif %}

{# --- Sniffer --- #}
{% if results.get('packet_sniffer') and results.packet_sniffer.status == 'success' %}
<section class="module" id="sniff">
  <h2>Packet sniffer</h2>
  <p class="muted">{{ results.packet_sniffer.packets_captured | default(0) }} pacotes · {{ results.packet_sniffer.duration_elapsed_s | default(results.packet_sniffer.duration) | default('—') }}s</p>
  {% set st = results.packet_sniffer.stats | default({}) %}
  <dl class="kv">
    <dt>DNS</dt><dd>{{ st.dns | default(0) }}</dd>
    <dt>HTTP</dt><dd>{{ st.http | default(0) }}</dd>
    <dt>HTTPS</dt><dd>{{ st.https | default(0) }}</dd>
    <dt>Outros</dt><dd>{{ st.other | default(0) }}</dd>
  </dl>
  {% set fd = results.packet_sniffer.findings | default({}) %}
  {% if fd.dns_queries %}
  <h3>Consultas DNS (todas)</h3>
  <p class="intel">{% for q in fd.dns_queries %}<span class="badge info">{{ q | e }}</span> {% endfor %}</p>
  {% endif %}
  {% if fd.http_hosts %}
  <h3>Hosts HTTP</h3>
  <p class="mono muted cell-long">{{ fd.http_hosts | join(', ') | e }}</p>
  {% endif %}
  {% if fd.cleartext_risk %}
  <h3>Risco texto claro</h3>
  {% for c in fd.cleartext_risk %}
  <div class="alert high">{{ c.type | e }}: {{ c.detail | default('') | e }}</div>
  {% endfor %}
  {% endif %}
  <details class="json-raw"><summary>JSON completo — Packet sniffer</summary>{{ results.packet_sniffer | json_pretty }}</details>
</section>
{% endif %}

{# --- Status de todos os módulos --- #}
<section class="module" id="raw">
  <h2>Estado bruto dos módulos</h2>
  <table class="data">
    <thead><tr><th>Módulo</th><th>Status</th></tr></thead>
    <tbody>
    {% for name, data in results | dictsort %}
      <tr>
        <td class="mono">{{ module_labels.get(name, name) | e }}</td>
        <td>{{ data.status | default('—') | e }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  <details class="json-raw"><summary>JSON completo — objeto <code>results</code> (todos os módulos)</summary>{{ results | json_pretty }}</details>
</section>

</main>

<footer>
  <p><strong>GhostOpcode</strong> v{{ version | e }} — gerado em {{ generated | e }}</p>
  <p>Apenas para alvos autorizados — use de forma responsável. Os autores não se responsabilizam por uso indevido.</p>
</footer>

</body>
</html>
