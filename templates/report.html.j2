  <table class="data">
    <thead><tr><th>Método</th><th>HTTP</th><th>Risco</th><th>Nota</th></tr></thead>
    <tbody>
    {% for meth, info in block.methods_tested | default({}) | dictsort %}
      <tr>
        <td>{{ meth | e }}</td>
        <td>{{ info.status | default('—') }}</td>
        {% set rk = info.risk | default('INFO') %}
        <td><span class="badge {{ rk | lower | e }}">{{ rk | e }}</span></td>
        <td class="cell-long">{{ info.note | default('—') | string | e }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endfor %}
  {% if results.http_methods.errors | default([]) %}
  <h3>Erros</h3>
  <ul class="compact">{% for e in results.http_methods.errors %}<li>{{ e | e }}</li>{% endfor %}</ul>
  {% endif %}
  <details class="json-raw"><summary>JSON completo — HTTP methods</summary>{{ results.http_methods | json_pretty }}</details>
</section>
{% endif %}

