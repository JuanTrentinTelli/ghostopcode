      <td>{% set sev = flag.severity | default('LOW') %}<span class="badge {{ sev | lower | e }}">{{ sev | e }}</span></td>
      <td>{{ flag.message | default(flag.title | default(flag | string)) | e }}</td>
      <td class="cell-long">{% if flag.detail %}{{ flag.detail | e }}{% elif flag.code is defined %}{{ flag.code | e }}{% else %}—{% endif %}</td>
    </tr>
    {% endfor %}
  </tbody></table>
  {% endif %}
  {% if results.whois_scan.errors | default([]) %}
  <h3>Erros</h3>
  <ul class="compact">{% for e in results.whois_scan.errors %}<li>{{ e | e }}</li>{% endfor %}</ul>
  {% endif %}
  <details class="json-raw"><summary>JSON completo — WHOIS scan</summary>{{ results.whois_scan | json_pretty }}</details>
</section>
{% endif %}

